# Copy this file to .env before starting the stack.

# Container image versions
POSTGRES_VERSION=16-alpine
REDIS_VERSION=7.4-alpine
CONFLUENT_VERSION=7.7.1
FINSHIELD_BACKEND_VERSION=local
FINSHIELD_ML_VERSION=local
FINSHIELD_UI_VERSION=local

# PostgreSQL
POSTGRES_DB=finshield
POSTGRES_USER=finshield
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=replace-with-a-strong-local-password
REDIS_PORT=6379

# Kafka
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=localhost

# Backend
BACKEND_PORT=8080
ML_SERVICE_PORT=8000
FRONTEND_PORT=4200
ML_SERVICE_TIMEOUT=2s
AML_FUZZY_THRESHOLD=0.88
AML_STRUCTURING_THRESHOLD=10000
AML_STRUCTURING_MINIMUM_COUNT=3
AML_MULE_MINIMUM_INCOMING=3
AML_MULE_MINIMUM_OUTGOING=2
AML_MULE_OUTFLOW_RATIO=0.70
AML_RAPID_MOVEMENT_WINDOW=30m
AML_RAPID_MOVEMENT_RATIO=0.50
AML_ROUND_AMOUNT_UNIT=1000
AML_ROUND_AMOUNT_MINIMUM_COUNT=3
# Comma-separated deployment policy; maintain this from your approved jurisdiction source.
AML_HIGH_RISK_COUNTRIES=IRAN,NORTH KOREA,SYRIA,MYANMAR
# Use validate with managed migrations in production.
JPA_DDL_AUTO=update

# Authentication (use at least 32 random characters)
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_ACCESS_TOKEN_TTL=15m

# Kafka topic sizing (replicas must remain 1 for the single-broker Compose stack)
TRANSACTION_INCOMING_PARTITIONS=6
TRANSACTION_INCOMING_REPLICAS=1
TRANSACTION_RISK_SCORED_PARTITIONS=6
TRANSACTION_RISK_SCORED_REPLICAS=1
KAFKA_CONSUMER_CONCURRENCY=3
FRAUD_ALERT_CREATED_PARTITIONS=3
FRAUD_ALERT_CREATED_REPLICAS=1
FRAUD_ALERT_PUBLISH_DELAY=2s

# When true, every critical alert also opens an investigation case.
AUTO_CREATE_CRITICAL_CASE=false

# Comma-separated frontend origins allowed to establish WebSocket connections.
WEBSOCKET_ALLOWED_ORIGINS=http://localhost:4200
